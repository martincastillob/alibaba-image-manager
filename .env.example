# Credenciales de Cloudinary. Obtenlas gratis (sin tarjeta) en:
# https://cloudinary.com/users/register_free
# Las encuentras en el Dashboard tras registrarte.
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# Puerto del servidor (Vercel lo asigna automáticamente; en local usa 3000)
PORT=3000
